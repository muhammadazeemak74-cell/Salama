# Copy this file to .env.local and fill in real values.
# NEVER commit real secrets. See CLAUDE.md "Conventions".

# OpenAI (NOT used in Phase 1 scaffold — placeholder for AI processing later)
OPENAI_API_KEY=

# WhatsApp Cloud API (Meta)
# Long-lived access token used to call the Graph API to send messages.
WHATSAPP_TOKEN=
# Arbitrary string you choose; must match the "verify token" you set when
# subscribing the webhook in the Meta App dashboard.
WHATSAPP_VERIFY_TOKEN=
# The phone number ID for your WhatsApp Business number.
WHATSAPP_PHONE_ID=

# Supabase
SUPABASE_URL=
# Server-side only. Has elevated privileges — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
